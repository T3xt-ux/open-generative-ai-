# Open Generative AI — Environment Variables
# Copy to .env.local for local development, or set in Vercel/Docker environment

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Proxy debug logging (set to '1' to enable request logs in API routes) ───
# WARNING: logs partial paths; never enable in production with sensitive key data
MUAPI_PROXY_DEBUG=0

# ─── Upload Proxy ─────────────────────────────────────────────────────────────
# Comma-separated list of additional upload target hosts allowed beyond S3.
# S3 hosts (*.s3.amazonaws.com, s3.amazonaws.com) are always allowed.
# Leave empty unless you're using a custom S3-compatible storage endpoint.
UPLOAD_PROXY_ALLOWED_HOSTS=
