{
  "name": "open-generative-ai-t3",
  "framework": "nextjs",
  "buildCommand": "git submodule update --init --recursive || true && npm run build:packages && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "MUAPI_PROXY_DEBUG": "0",
    "UPLOAD_PROXY_ALLOWED_HOSTS": "",
    "VERCEL_AUTOMATION_BYPASS_SECRET": "t3-open-gen-ai-bypass-2026"
  },
  "functions": {
    "app/api/**/*.js": {
      "maxDuration": 60
    },
    "app/api/t3/generate/route.js": {
      "maxDuration": 120
    }
  }
}
